{
    "name": "zeevx/laravel-brimble-sandbox",
    "description": "Laravel integration for the Brimble Sandbox PHP SDK: config, container binding, facade, and Artisan commands.",
    "keywords": ["brimble", "sandbox", "laravel", "sdk", "api"],
    "homepage": "https://github.com/zeevx/laravel-brimble-sandbox",
    "license": "MIT",
    "authors": [
        {
            "name": "Zeevx",
            "email": "adamsohiani@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "zeevx/php-brimble-sandbox": "^0.1",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.5",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Zeevx\\LaravelBrimbleSandbox\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zeevx\\LaravelBrimbleSandbox\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint",
        "analyse": "phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zeevx\\LaravelBrimbleSandbox\\BrimbleSandboxServiceProvider"
            ],
            "aliases": {
                "BrimbleSandbox": "Zeevx\\LaravelBrimbleSandbox\\Facades\\BrimbleSandbox"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}